  "narration": {
    "engine": "f5-tts-local",
    "language": "zh-CN",
    "referenceAudioPath": "assets/voice-reference.wav",
    "referenceText": "夜市刚亮灯，橘猫的炒粉摊开张了。客人说少辣，它先把铁锅烧到冒烟。米粉一落锅，它左爪倒粉，右爪稳住锅柄。豆芽鸡蛋一翻，香气飘过半条街。酱油沿锅边一淋，火苗呼地窜起来。锅一颠，炒粉划道弧线，稳稳落回去。热腾腾的一盘递出去，客人的尾巴先摇了。",
    "speed": 0.5,
    "segments": [
      {
        "segmentId": "closing-market-line",
        "shotId": "closing-market",
        "text": "夜市都开始收摊了，卷帘门一扇接一扇落下，只有街角这只小猫还守着炉火。",
        "outputPath": "generated/audio/segments/closing-market.wav"
      },
      {
        "segmentId": "last-pan-line",
        "shotId": "last-pan",
        "text": "锅里只剩最后一份炒粉，它两只爪子握紧锅铲，翻得比谁都认真。",
        "outputPath": "generated/audio/segments/last-pan.wav"
      },
      {
        "segmentId": "aroma-corner-line",
        "shotId": "aroma-corner",
        "text": "香气绕过路灯，拐了个弯，把最后一位赶路的客人勾了回来。",
        "outputPath": "generated/audio/segments/aroma-corner.wav"
      },
      {
        "segmentId": "warm-handoff-line",
        "shotId": "warm-handoff",
        "text": "小猫把热腾腾的晚餐递过去，客人笑了。今晚这摊，刚好一份不剩。",
        "outputPath": "generated/audio/segments/warm-handoff.wav"
      }
    ],
    "mergedAudioPath": "generated/audio/narration.wav"
  },
