{
  "name": "gen-video-tool",
  "version": "0.1.0",
  "private": true,
  "description": "Local-first AI video generator and deterministic video composer",
  "type": "module",
  "main": "./out/main/index.js",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer": "vite --config vite.renderer.config.ts",
    "build:desktop": "electron-vite build",
    "desktop:launch": "electron .",
    "desktop:shortcut": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/create-desktop-shortcut.ps1",
    "preview:desktop": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:desktop-startup": "node scripts/electron-startup-smoke.mjs",
    "benchmark:wangp:desktop": "node scripts/electron-wangp-benchmark.mjs",
    "validate:production": "tsx scripts/validate-production.ts",
    "verify:asset-pack": "tsx scripts/verify-asset-pack-roundtrip.ts",
    "narrate:production": "tsx scripts/synthesize-production.ts",
    "render:production": "tsx scripts/render-production.ts",
    "paper:production": "tsx scripts/paper-collage-production.ts",
    "paper:stylize": "tsx scripts/stylize-paper-cutout.ts",
    "local:production": "tsx scripts/local-production-cli.ts",
    "local:production:detect": "tsx scripts/local-production-cli.ts detect",
    "local:production:status": "tsx scripts/local-production-cli.ts status",
    "local:production:generate": "tsx scripts/local-production-cli.ts generate",
    "local:production:select": "tsx scripts/local-production-cli.ts select",
    "local:production:reject": "tsx scripts/local-production-cli.ts reject",
    "codex:studio": "node scripts/start-codex-plugin.mjs --web-only",
    "codex:mcp": "tsx apps/codex-studio/src/mcp.ts",
    "codex:plugin": "node scripts/start-codex-plugin.mjs",
    "test:codex-plugin": "node scripts/probe-codex-plugin.mjs",
    "rife:frames": "tsx scripts/rife-interpolate.ts",
    "qa:frames": "tsx scripts/make-contact-sheets.ts",
    "qa": "npm run typecheck && npm run test && npm run validate:production -- examples/morning-light-v3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@remotion/player": "4.0.489",
    "express": "5.2.1",
    "jszip": "3.10.1",
    "lucide-react": "1.24.0",
    "music-metadata": "11.14.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.489",
    "sharp": "0.35.3",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@remotion/bundler": "4.0.489",
    "@remotion/renderer": "4.0.489",
    "@types/node": "26.1.1",
    "@types/express": "5.0.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.1",
    "electron-vite": "5.0.0",
    "playwright": "1.61.1",
    "tsx": "4.23.1",
    "typescript": "5.9.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "license": "MIT"
}
