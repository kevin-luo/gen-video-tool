{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Gen Video Tool Motion Worker Request",
  "type": "object",
  "required": ["protocolVersion", "requestId", "projectId", "actorId", "texturePath", "rigPath", "action", "output"],
  "properties": {
    "protocolVersion": {"const": 1},
    "requestId": {"type": "string", "minLength": 1},
    "projectId": {"type": "string", "minLength": 1},
    "actorId": {"type": "string", "minLength": 1},
    "texturePath": {"type": "string", "minLength": 1},
    "rigPath": {"type": "string", "minLength": 1},
    "action": {
      "type": "object",
      "required": ["template", "durationInFrames", "fps", "amplitude"],
      "properties": {
        "template": {"enum": ["idle-breathe", "look-down", "look-left", "look-right", "reach", "point", "small-step", "celebrate", "nod", "shoulder-relax"]},
        "durationInFrames": {"type": "integer", "minimum": 1, "maximum": 1800},
        "fps": {"type": "integer", "minimum": 1, "maximum": 120},
        "amplitude": {"type": "number", "minimum": 0, "maximum": 1}
      }
    },
    "output": {
      "type": "object",
      "required": ["directory", "format", "width", "height"],
      "properties": {
        "directory": {"type": "string", "minLength": 1},
        "format": {"enum": ["png-sequence", "transparent-webm", "alpha-mov"]},
        "width": {"type": "integer", "minimum": 1, "maximum": 8192},
        "height": {"type": "integer", "minimum": 1, "maximum": 8192}
      }
    }
  }
}
